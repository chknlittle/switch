{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "kimi-for-coding": {
      "models": {
        "kimi-k2.6": {
          "name": "Kimi K2.6 (Coding)",
          "limit": {
            "context": 262144,
            "output": 32768
          }
        }
      }
    },
    "glm_vllm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OpenAI-compatible vLLM",
      "options": {
        "baseURL": "http://127.0.0.1:8027/v1"
      },
      "models": {
        "qwen3.5-35b-a3b-awq4": {
          "name": "Qwen3.5 35B A3B AWQ 4-bit",
          "limit": {
            "context": 131072,
            "output": 8192
          }
        }
      }
    },
    "epstein_vllm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "EpsteinLM vLLM",
      "options": {
        "baseURL": "http://127.0.0.1:8030/v1"
      },
      "models": {
        "alphakek-epsteinLM-synth-2602-ckpt4": {
          "name": "epsteinLM synth 2602 ckpt4 (8B FP16)",
          "limit": {
            "context": 32768,
            "output": 4096
          }
        }
      }
    },
    "spark_llama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Spark llama.cpp",
      "options": {
        "baseURL": "http://127.0.0.1:18080/v1"
      },
      "models": {
        "qwen3.5-122b-a10b-mxfp4-moe": {
          "name": "Qwen3.5 122B A10B MXFP4_MOE (Spark)",
          "limit": {
            "context": 262144,
            "output": 8192
          }
        }
      }
    },
    "qwen36_a3b_vllm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Spark Qwen3.6-35B-A3B abliterated API",
      "options": {
        "baseURL": "http://127.0.0.1:18080/v1"
      },
      "models": {
        "qwen3.6-35b-a3b-abliterated": {
          "name": "Qwen3.6-35B-A3B-abliterated (huihui Claude-4.7-Opus distill, FP16, Spark GB10)",
          "options": {
            "maxTokens": 65536,
            "temperature": 1.0,
            "top_p": 0.95,
            "top_k": 20,
            "min_p": 0.0,
            "presence_penalty": 1.5,
            "frequency_penalty": 0.0,
            "repetition_penalty": 1.0,
            "chat_template_kwargs": {
              "enable_thinking": true,
              "preserve_thinking": true
            },
            "reasoning": {
              "enabled": true
            }
          },
          "limit": {
            "context": 262144,
            "output": 65536
          }
        }
      }
    },
    "heretic_local": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Helga Heretic API",
      "options": {
        "baseURL": "http://127.0.0.1:8021/v1"
      },
      "models": {
        "heretic-v3": {
          "name": "Qwen3.5 27B Heretic v3 (vLLM)",
          "options": {
            "maxTokens": 32768,
            "reasoning": {
              "enabled": false
            },
            "chat_template_kwargs": {
              "enable_thinking": false
            }
          },
          "limit": {
            "context": 130144,
            "output": 32768
          }
        },
        "heretic-v3-thinking": {
          "id": "heretic-v3",
          "name": "Qwen3.5 27B Heretic v3 (thinking)",
          "options": {
            "maxTokens": 32768,
            "reasoning": {
              "enabled": true
            },
            "chat_template_kwargs": {
              "enable_thinking": true
            }
          },
          "limit": {
            "context": 130144,
            "output": 32768
          }
        }
      }
    },
    "openrouter": {
      "models": {
